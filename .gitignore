node_modules
dist

# Local env files (never commit real keys)
.env
.env.local
.env.*.local

# Ignore the output video from Git but not videos you import into src/.
out
# Allow metrics.json verdicts from review runs (pinned proof of gate state)
!out/
!out/review/
!out/review/*/
!out/review/*/hook/
!out/review/*/hook/metrics.json
!out/review/*/hook-tournament/
!out/review/*/hook-tournament/ranking.json
!out/review/*/hook-tournament/summary.txt
!out/review/*/musicsync/
!out/review/*/musicsync/metrics.json
!out/review/*/payoff/
!out/review/*/payoff/metrics.json
!out/review/*/distinct/
!out/review/*/distinct/metrics.json

# Generated smoke-test media
public/smoke
public/review-tmp

# scaffold-smoke temp artifacts (auto-removed by scripts/scaffold-smoke.mjs; gitignored as safety net)
src/videos/scaffold-smoke/
public/scaffold-smoke/
out/review/ScaffoldSmoke/
out/review/scaffold-smoke/

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode
.idea
*.log

# Test coverage
coverage

# Playwright auth sessions (per-app QA logins), if you add capture scripts
scripts/capture/.auth

# Antigravity CLI configurations
.antigravitycli
